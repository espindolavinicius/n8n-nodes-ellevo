               },
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/espindolavinicius/n8n-nodes-ellevo.git"
                   },
    "bugs":  {
                 "url":  "https://github.com/espindolavinicius/n8n-nodes-ellevo/issues"
             },
    "main":  "index.js",
    "scripts":  {
